# =============================================================================
# DATABASE - PostgreSQL (Coolify Built-in)
# =============================================================================
# Use Coolify's PostgreSQL database connection string
# Format: postgresql://username:password@host:port/database
# Find this in Coolify Dashboard > Database > PostgreSQL > Connection Details
DATABASE_URL=postgresql://postgres:your_password@10.0.0.1:5432/kygoo_frame_studio

# =============================================================================
# SESSION - Iron Session
# =============================================================================
# Generate a secure random string (min 32 characters)
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-secure-session-secret-min-32-characters

# =============================================================================
# UPLOADS - Coolify Persistent Storage
# =============================================================================
# Path for uploaded files (inside container)
UPLOAD_DIR=/app/uploads

# =============================================================================
# Optional: Redis for Session/Rate Limiting (if using)
# =============================================================================
# REDIS_URL=redis://localhost:6379

# =============================================================================
# Optional: Sentry Error Monitoring
# =============================================================================
# SENTRY_DSN=https://example@sentry.io/project

# =============================================================================
# Optional: Analytics
# =============================================================================
# NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
